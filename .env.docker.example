# ============================================
# DOCKER DEPLOYMENT CONFIGURATION TEMPLATE
# ============================================
# Copy this file to .env and fill in real values before deploying
# NEVER commit this file with real credentials
# ============================================

# Host Ports (change to avoid conflicts)
APP_PORT=3010
MONGO_PORT=27020

# MongoDB (internal Docker network)
MONGODB_URI=mongodb://mongo:27017/maquinaria

# NextAuth
# Cambiar IP/dominio al del servidor donde se despliega
NEXTAUTH_URL=http://YOUR_SERVER_IP:3010
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=

# Email Configuration (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
EMAIL_FROM=
EMAIL_FROM_NAME=Orchard Service

# Email Configuration (Gmail - fallback)
EMAIL_APP_PASSWORD=

# Cron Job Security
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET_TOKEN=

# App Settings
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=http://YOUR_SERVER_IP:3010
